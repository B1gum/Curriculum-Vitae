\def\sd@x{0}
\def\sd@y{0}

\newcommand{\sd@lang}[2]{\iflanguage{danish}{#1}{#2}}
\newcommand{\StudyDiagramText}[2]{\iflanguage{danish}{#1}{#2}}
\newcommand{\sd@txtStudy}{\sd@lang{STUDIE}{STUDY}}
\newcommand{\sd@txtDiagram}{\sd@lang{DIAGRAM}{DIAGRAM}}
\newcommand{\sd@txtCourseType}{\sd@lang{KURSUSTYPE}{COURSE TYPE}}
\newcommand{\sd@txtStatus}{\sd@lang{STATUS}{STATUS}}
\newcommand{\sd@txtObligatory}{\sd@lang{OBLIGATORISK}{OBLIGATORY}}
\newcommand{\sd@txtElective}{\sd@lang{VALGFAG}{ELECTIVE}}
\newcommand{\sd@txtAdditional}{\sd@lang{TILVALG}{OPTIONAL}}
\newcommand{\sd@txtSupport}{\sd@lang{ST\O TTEFAG}{SUPPORT}}
\newcommand{\sd@txtCompleted}{\sd@lang{BEST\AA ET}{COMPLETED}}
\newcommand{\sd@txtCurrent}{\sd@lang{IGANGV\AE RENDE}{CURRENT}}
