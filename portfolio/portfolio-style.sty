
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{portfolio/portfolio-style}[2026/05/01 Unified project portfolio styling]

\RequirePackage{cv-style}

\RequirePackage{fancyhdr}

\newcommand{\portfoliofooterlabel}{Engineering Portfolio}

\newcommand{\setupportfoliofooter}{%
  \pagestyle{fancy}%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
  \fancyfoot[L]{\footnotesize\color{CVMuted}\today}%
  \fancyfoot[R]{\footnotesize\color{CVMuted}Noah Rahbek Bigum Hansen~~~·~~~\portfoliofooterlabel}%
}


\NewDocumentCommand{\portfoliotag}{m}{%
  \tikz[baseline=(tag.base)]{%
    \node[
      anchor=base,
      rounded corners=1pt,
      draw=CVBlue!35,
      fill=CVBlue!7,
      inner xsep=4.2pt,
      inner ysep=1.6pt,
      font=\sffamily\bfseries\scriptsize,
      text=AUblueDark
    ] (tag) {#1};%
  }%
}

\NewDocumentEnvironment{projectbullets}{}{% 
  \begin{itemize}[leftmargin=2.1ex, topsep=1mm, itemsep=0.6mm]
    \setlength{\parskip}{0pt}
    \renewcommand{\labelitemi}{\textcolor{CVBlue}{\scriptsize\textbullet}}
}{%
  \end{itemize}%
}

\NewDocumentCommand{\projectimagebox}{m}{%
  \begin{tikzpicture}
    \node {#1};
  \end{tikzpicture}%
}

\NewDocumentCommand{\portfoliolead}{m}{%
  \begin{cvparagraph}
  \fontsize{9pt}{1.18em}\bodyfontlight\upshape\color{CVText}%
  \vspace{-5pt}#1
  \end{cvparagraph}
}

\NewDocumentCommand{\projectentry}{m m m m m m +m}{%
  \vspace{-2.8mm}%
  \setlength\tabcolsep{0pt}%
  \noindent
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\dimexpr\textwidth-7cm\relax} R{7cm}}
    \entrytitlestyle{#1} & \entrylocationstyle{#3} \\
    \entrypositionstyle{#2} & \entrydatestyle{#4} \\
  \end{tabular*}%
  \vspace{0.8mm}%
  \noindent\begin{tcolorbox}[
    width=\textwidth,
    colback=PortfolioSoft,
    colframe=PortfolioSoft,
    boxrule=0pt,
    left=2.8mm,
    right=2.8mm,
    top=2.0mm,
    bottom=1.6mm,
    boxsep=0pt,
    before skip=0pt,
    after skip=0pt
  ]
    \begin{minipage}[t]{0.72\linewidth}
      {\fontsize{9pt}{1.18em}\bodyfontlight\upshape\color{CVText}%
        {#5\par}\vspace{1.8mm}%
        #7%
      }%
    \end{minipage}%
    \hfill%
    \begin{minipage}[t]{0.27\linewidth}
      \vspace{0pt}\raggedleft
      #6
    \end{minipage}%
  \end{tcolorbox}%
  \par\vspace{3.8mm}%
}

\NewDocumentCommand{\projectseparator}{}{% 
  \vspace{-0.6mm}\noindent\textcolor{PortfolioLine}{\rule{\textwidth}{0.15pt}}\vspace{1.0mm}%
}

