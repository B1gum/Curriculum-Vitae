\newcommand{\flapfigure}{%
\projectimagebox{%
\begin{tikzpicture}[x=0.55cm,y=0.55cm, line cap=round, line join=round]
  \fill[PortfolioSoft] (0,0) rectangle (6.4,4.4);
  \draw[CVBlue!55, line width=0.7pt, rounded corners=1.4pt] (0.2,0.2) rectangle (6.2,4.2);
  \fill[CVBlue!10, rounded corners=1pt] (0.6,0.75) rectangle (2.05,1.75);
  \draw[AUblueDark, line width=0.8pt] (0.75,1.25) circle (0.25);
  \draw[AUblueDark, line width=0.8pt] (1.5,1.25) circle (0.25);
  \draw[AUblueDark, line width=0.8pt] (2.1,1.25) -- (3.2,1.25);
  \fill[PortfolioOrange!55] (3.25,0.8) -- (5.75,1.1) -- (5.95,1.55) -- (3.25,1.75) -- cycle;
  \draw[AUblueDark, line width=0.9pt] (3.25,0.8) -- (5.75,1.1) -- (5.95,1.55) -- (3.25,1.75) -- cycle;
  \draw[CVBlue, line width=0.75pt, -{Latex[length=2mm]}] (4.2,2.25) arc[start angle=80, end angle=25, radius=0.9];
  \node[font=\scriptsize\bfseries\color{AUblueDark}] at (1.25,2.55) {DC motor};
  \node[font=\scriptsize\bfseries\color{AUblueDark}] at (4.75,2.65) {flap};
