}}

\newcommand{\pedalfigure}{%
\projectimagebox{%
\begin{tikzpicture}[x=0.55cm,y=0.55cm, line cap=round, line join=round]
  \fill[PortfolioSoft] (0,0) rectangle (6.4,4.4);
  \draw[CVBlue!55, line width=0.7pt, rounded corners=1.4pt] (0.2,0.2) rectangle (6.2,4.2);
  \foreach \x/\lab in {1.0/GAIN,2.4/TONE,3.8/VOL} {
    \draw[AUblueDark, line width=0.8pt] (\x,3.1) circle (0.38);
    \draw[AUblueDark, line width=0.8pt] (\x,3.1) -- ++(0.18,0.22);
    \node[font=\tiny\bfseries\color{AUblueDark}] at (\x,2.45) {\lab};
  }
  \fill[PortfolioOrange!45, rounded corners=1pt] (0.85,0.65) rectangle (5.55,1.65);
  \draw[AUblueDark, line width=0.8pt, rounded corners=1pt] (0.85,0.65) rectangle (5.55,1.65);
  \foreach \x in {1.15,1.65,...,5.25}{\draw[CVBlue!70] (\x,0.75) -- (\x,1.55);}
  \node[font=\scriptsize\bfseries\color{AUblueDark}] at (3.2,1.15) {gain / clipping / tone};
\end{tikzpicture}%
}}
